{
  "name": "kpuppy",
  "version": "0.0.29",
  "description": "KinoPub client for LG webOS TV",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "package": "ares-package dist -o .",
    "deploy": "ares-install *.ipk",
    "lint": "eslint src/",
    "lint:css": "stylelint 'src/**/*.css'"
  },
  "browserslist": [
    "Chrome 53"
  ],
  "dependencies": {
    "@sentry/browser": "^10.32.1",
    "preact": "^10.25.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@preact/preset-vite": "^2.9.4",
    "@testing-library/preact": "^3.2.4",
    "eslint": "^9.39.2",
    "jsdom": "^25.0.1",
    "stylelint": "^17.1.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-no-unsupported-browser-features": "^8.1.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.54.0",
    "vite": "^6.0.6",
    "vitest": "^2.1.8",
    "ws": "^8.18.3"
  }
}
